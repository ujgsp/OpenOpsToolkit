---
# YAML Lint Configuration
# OpenOps Toolkit

extends: default

rules:
  line-length:
    max: 200
    allow-non-breakable-words: true
    allow-non-breakable-inline-mappings: true
  
  indentation:
    spaces: 2
    indent-sequences: true
    check-multi-line-strings: false
  
  truthy:
    allowed-values: ['true', 'false', 'yes', 'no']
    check-keys: false
  
  comments:
    min-spaces-from-content: 1
  
  document-start: disable
  
  empty-lines:
    max: 2
    max-start: 0
    max-end: 0
  
  hyphens:
    max-spaces-after: 1
  
  brackets:
    min-spaces-inside: 0
    max-spaces-inside: 1
  
  commas:
    max-spaces-before: 0
    min-spaces-after: 1
    max-spaces-after: 1

ignore: |
  .git/
  node_modules/
  .github/workflows/*.yml