#!/bin/bash
# {{ ansible_managed }}
# Server Backup Script
# Runs daily via cron

set -euo pipefail

TIMESTAMP=$(date +%Y%m%d_%H%M%S)
BACKUP_DIR="{{ backup_path }}"
BACKUP_FILE="${BACKUP_DIR}/server-backup-${TIMESTAMP}.tar.gz"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

log() {
    echo -e "${GREEN}[$(date '+%Y-%m-%d %H:%M:%S')]${NC} $1"
}

warn() {
    echo -e "${YELLOW}[$(date '+%Y-%m-%d %H:%M:%S')] WARNING:${NC} $1"
}

error() {
    echo -e "${RED}[$(date '+%Y-%m-%d %H:%M:%S')] ERROR:${NC} $1"
    exit 1
}

log "Starting server backup..."

# Create backup directory if not exists
mkdir -p "${BACKUP_DIR}"

# Create temporary directory for backup
TEMP_DIR=$(mktemp -d)
trap "rm -rf ${TEMP_DIR}" EXIT

# Backup configuration files
log "Backing up configuration files..."
{% for path in backup_paths %}
if [ -d "{{ path }}" ]; then
    cp -a "{{ path }}" "${TEMP_DIR}/" 2>/dev/null || warn "Could not backup {{ path }}"
fi
{% endfor %}

# Backup cron jobs
log "Backing up cron jobs..."
crontab -l > "${TEMP_DIR}/crontab-root.txt" 2>/dev/null || true

# Backup installed packages list
log "Backing up installed packages list..."
dpkg --get-selections > "${TEMP_DIR}/packages-selections.txt" 2>/dev/null || true

# Backup system information
log "Backing up system information..."
echo "Backup created: $(date)" > "${TEMP_DIR}/backup-info.txt"
echo "Hostname: $(hostname)" >> "${TEMP_DIR}/backup-info.txt"
echo "Kernel: $(uname -r)" >> "${TEMP_DIR}/backup-info.txt"
echo "Uptime: $(uptime)" >> "${TEMP_DIR}/backup-info.txt"

# Create compressed archive
log "Creating compressed archive..."
tar -czf "${BACKUP_FILE}" -C "${TEMP_DIR}" . 2>/dev/null

# Calculate backup size
BACKUP_SIZE=$(du -h "${BACKUP_FILE}" | cut -f1)
log "Backup completed: ${BACKUP_FILE} (${BACKUP_SIZE})"

# Cleanup old backups (handled by cleanup script)
log "Backup script finished successfully."
