#!/bin/bash
# {{ ansible_managed }}
# Backup Cleanup Script
# Runs weekly via cron to remove old backups

set -euo pipefail

BACKUP_DIR="{{ backup_path }}"
RETENTION_DAYS="{{ backup_retention_days }}"

# Colors for output
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

log() {
    echo -e "${GREEN}[$(date '+%Y-%m-%d %H:%M:%S')]${NC} $1"
}

warn() {
    echo -e "${YELLOW}[$(date '+%Y-%m-%d %H:%M:%S')] WARNING:${NC} $1"
}

log "Starting backup cleanup..."
log "Retention period: ${RETENTION_DAYS} days"

# Count files before cleanup
BEFORE_COUNT=$(find "${BACKUP_DIR}" -type f -name "*.tar.gz" -o -name "*.sql.gz" 2>/dev/null | wc -l)
BEFORE_SIZE=$(du -sh "${BACKUP_DIR}" 2>/dev/null | cut -f1)

# Remove old server backups
log "Removing server backups older than ${RETENTION_DAYS} days..."
find "${BACKUP_DIR}" -type f -name "server-backup-*.tar.gz" -mtime +${RETENTION_DAYS} -delete 2>/dev/null || true

# Remove old MySQL backups
log "Removing MySQL backups older than ${RETENTION_DAYS} days..."
find "${BACKUP_DIR}/mysql" -type f -name "*.sql.gz" -mtime +${RETENTION_DAYS} -delete 2>/dev/null || true

# Remove old backup info files
find "${BACKUP_DIR}/mysql" -type f -name "backup-info-*.txt" -mtime +${RETENTION_DAYS} -delete 2>/dev/null || true

# Remove empty directories
find "${BACKUP_DIR}" -type d -empty -delete 2>/dev/null || true

# Count files after cleanup
AFTER_COUNT=$(find "${BACKUP_DIR}" -type f -name "*.tar.gz" -o -name "*.sql.gz" 2>/dev/null | wc -l)
AFTER_SIZE=$(du -sh "${BACKUP_DIR}" 2>/dev/null | cut -f1)

REMOVED=$((BEFORE_COUNT - AFTER_COUNT))
log "Cleanup completed."
log "Files before: ${BEFORE_COUNT} | After: ${AFTER_COUNT} | Removed: ${REMOVED}"
log "Size before: ${BEFORE_SIZE} | After: ${AFTER_SIZE}"
log "Cleanup script finished successfully."
