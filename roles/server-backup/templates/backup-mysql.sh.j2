#!/bin/bash
# {{ ansible_managed }}
# MySQL Backup Script
# Runs daily via cron

set -euo pipefail

TIMESTAMP=$(date +%Y%m%d_%H%M%S)
BACKUP_DIR="{{ backup_path }}/mysql"
BACKUP_FILE="${BACKUP_DIR}/mysql-backup-${TIMESTAMP}.sql.gz"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

log() {
    echo -e "${GREEN}[$(date '+%Y-%m-%d %H:%M:%S')]${NC} $1"
}

warn() {
    echo -e "${YELLOW}[$(date '+%Y-%m-%d %H:%M:%S')] WARNING:${NC} $1"
}

error() {
    echo -e "${RED}[$(date '+%Y-%m-%d %H:%M:%S')] ERROR:${NC} $1"
    exit 1
}

log "Starting MySQL backup..."

# Create backup directory if not exists
mkdir -p "${BACKUP_DIR}"

{% if backup_mysql_databases | length > 0 %}
# Backup specific databases
DATABASES="{{ backup_mysql_databases | join(' ') }}"
{% else %}
# Backup all databases
DATABASES=$(mysql -u {{ backup_mysql_user }} {% if backup_mysql_password %}-p'{{ backup_mysql_password }}'{% endif %} -Bse "SHOW DATABASES" 2>/dev/null | grep -v -E "^(information_schema|performance_schema|sys)$")
{% endif %}

TOTAL_SIZE=0

for DB in $DATABASES; do
    log "Backing up database: ${DB}"
    
    DB_FILE="${BACKUP_DIR}/${DB}-${TIMESTAMP}.sql.gz"
    
    mysqldump -u {{ backup_mysql_user }} {% if backup_mysql_password %}-p'{{ backup_mysql_password }}'{% endif %} \
        --single-transaction \
        --routines \
        --triggers \
        --events \
        "${DB}" 2>/dev/null | pigz > "${DB_FILE}" || warn "Could not backup database: ${DB}"
    
    if [ -f "${DB_FILE}" ]; then
        DB_SIZE=$(du -h "${DB_FILE}" | cut -f1)
        log "  -> ${DB}: ${DB_SIZE}"
        TOTAL_SIZE=$((TOTAL_SIZE + $(stat -f%z "${DB_FILE}" 2>/dev/null || stat -c%s "${DB_FILE}" 2>/dev/null || echo 0)))
    fi
done

# Create a combined backup info
echo "MySQL Backup completed: $(date)" > "${BACKUP_DIR}/backup-info-${TIMESTAMP}.txt"
echo "Databases backed up: ${DATABASES}" >> "${BACKUP_DIR}/backup-info-${TIMESTAMP}.txt"

log "MySQL backup completed. Total databases: $(echo ${DATABASES} | wc -w)"
log "MySQL backup script finished successfully."
