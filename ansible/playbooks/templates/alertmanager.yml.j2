# Alertmanager Configuration
# Managed by Ansible

global:
  smtp_smarthost: 'smtp.gmail.com:587'
  smtp_from: 'alerts@{{ app_domain }}'
  smtp_auth_username: 'alerts@{{ app_domain }}'
  smtp_auth_password: '{{ vault_smtp_password }}'

route:
  group_by: ['alertname']
  group_wait: 10s
  group_interval: 10s
  repeat_interval: 1h
  receiver: 'web.hook'

receivers:
  - name: 'web.hook'
    email_configs:
      - to: 'admin@{{ app_domain }}'
        subject: 'Alert: {{ "{{" }} .GroupLabels.alertname {{ "}}" }}'
        body: |
          {{ "{{" }} range .Alerts {{ "}}" }}
          Alert: {{ "{{" }} .Annotations.summary {{ "}}" }}
          Description: {{ "{{" }} .Annotations.description {{ "}}" }}
          {{ "{{" }} end {{ "}}" }}
    
    webhook_configs:
      - url: 'http://{{ groups["monitoring"][0] }}:3000/api/v1/alerts'
        send_resolved: true

inhibit_rules:
  - source_match:
      severity: 'critical'
    target_match:
      severity: 'warning'
    equal: ['alertname', 'instance']